# GEMINI_API_KEY: Required for Gemini API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="https://pdv.heso.com.br"

# ===== SUPABASE =====
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_publishable_key
SUPABASE_SECRET_KEY=your_secret_key
SUPABASE_DB_HOST=db.your-project.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASS=your_database_password

# ===== AIQFOME =====
AIQFOME_CLIENT_ID=your_aiqfome_client_id
AIQFOME_CLIENT_SECRET=your_aiqfome_client_secret
AIQFOME_REDIRECT_URI=https://pdv.heso.com.br/api/aiqfome-callback.php

# ===== IFOOD =====
IFOOD_CLIENT_ID=your_ifood_client_id
IFOOD_CLIENT_SECRET=your_ifood_client_secret
IFOOD_REDIRECT_URI=https://pdv.heso.com.br/api/ifood-callback.php
IFOOD_WEBHOOK_SECRET=your_ifood_webhook_secret
