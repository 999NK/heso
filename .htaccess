<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Se o arquivo solicitado existe fisicamente na raiz, serve direto (ex: .well-known, etc)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Se o arquivo solicitado existe dentro de dist/ (ex: assets, imagens), serve de lá
  RewriteCond %{DOCUMENT_ROOT}/dist%{REQUEST_URI} -f
  RewriteRule ^(.*)$ dist/$1 [L]

  # Qualquer outra rota do React Router vai para dist/index.html
  RewriteRule . dist/index.html [L]
</IfModule>
