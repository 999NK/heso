<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Executa estas regras APENAS para o domínio principal (heso.com.br ou www.heso.com.br)
  # Impede que elas interfiram no subdomínio pdv.heso.com.br
  RewriteCond %{HTTP_HOST} ^(www\.)?heso\.com\.br$ [NC]
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Se o arquivo solicitado existe dentro de dist/, serve de lá
  RewriteCond %{HTTP_HOST} ^(www\.)?heso\.com\.br$ [NC]
  RewriteCond %{DOCUMENT_ROOT}/dist%{REQUEST_URI} -f
  RewriteRule ^(.*)$ dist/$1 [L]

  # Qualquer outra rota do React Router vai para dist/index.html
  RewriteCond %{HTTP_HOST} ^(www\.)?heso\.com\.br$ [NC]
  RewriteRule . dist/index.html [L]
</IfModule>
